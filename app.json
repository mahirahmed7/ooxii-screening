{
  "expo": {
    "name": "OOXii Screen",
    "slug": "ooxii-screening",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ooxii",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.ooxii.screening",
      "supportsTablet": true
    },
    "android": {
      "package": "app.ooxii.screening",
      "permissions": [],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow OOXii Screen to set a profile photo for the person running screenings."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30ddacda-0c2f-41b8-8ebf-9b27734a0786"
      }
    },
    "owner": "mahirahmed7"
  }
}
