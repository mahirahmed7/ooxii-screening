    "scheme": "ooxii",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.ooxii.screening",
      "supportsTablet": true
    },
    "android": {
      "package": "app.ooxii.screening"
    },
    "plugins": ["expo-router", "expo-sqlite"]
  }
}
